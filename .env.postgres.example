GEOWORKBENCH_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/geoworkbench
GEOWORKBENCH_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
GEOWORKBENCH_UPLOAD_ROOT=D:/Source/geoworkbench/runtime-data/uploads
GEOWORKBENCH_EXPORT_ROOT=D:/Source/geoworkbench/runtime-data/exports

GEOWORKBENCH_AI_PROVIDER=local_openai
GEOWORKBENCH_AI_BASE_URL=http://192.168.1.2:1234/v1
GEOWORKBENCH_AI_MODEL=google/gemma-4-e4b

GEOWORKBENCH_AUTH_TOKEN_HOURS=12
GEOWORKBENCH_MOBILE_OTP_MINUTES=10
GEOWORKBENCH_PUSH_PROVIDER=disabled
GEOWORKBENCH_PUSH_FCM_SERVER_KEY=
GEOWORKBENCH_PUSH_APNS_KEY_ID=
GEOWORKBENCH_PUSH_APNS_TEAM_ID=
GEOWORKBENCH_PUSH_APNS_BUNDLE_ID=
