GEOWORKBENCH_DATABASE_URL=sqlite:///./geoworkbench_dev.db
GEOWORKBENCH_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# Production examples:
# GEOWORKBENCH_DATABASE_URL=postgresql+psycopg://geoworkbench:password@db-server:5432/geoworkbench
# GEOWORKBENCH_UPLOAD_STORAGE=local
# GEOWORKBENCH_UPLOAD_ROOT=D:/GeoWorkbench/data/uploads
# GEOWORKBENCH_PUBLIC_BASE_URL=https://geoworkbench.example.com

# Future AI provider settings
GEOWORKBENCH_AI_PROVIDER=disabled
GEOWORKBENCH_AI_MODEL=
GEOWORKBENCH_AI_BASE_URL=
GEOWORKBENCH_AI_API_KEY=
